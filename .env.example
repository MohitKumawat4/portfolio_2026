# ===========================================
# PORTFOLIO ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill values
# ===========================================

# -------------------------------------------
# EMAIL (Contact Form - Nodemailer)
# -------------------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@sainiamit.com
SMTP_PASS=your_email_password_here

# -------------------------------------------
# RAZORPAY (Support/Donation Payments)
# -------------------------------------------
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# -------------------------------------------
# SITE URL (for SEO & callbacks)
# -------------------------------------------
NEXT_PUBLIC_SITE_URL=https://sainiamit.com
